# Database — local Docker or Neon
# Local: postgresql+asyncpg://postgres:dev@localhost:5432/devshowcase
# Neon:  postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/devshowcase?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/devshowcase

# Anthropic (required — Claude powers repo analysis and post generation)
ANTHROPIC_API_KEY=
# Claude model for analysis and generation (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LangGraph checkpointer (optional — PostgreSQL psycopg3 URL for pipeline state)
# Use standard postgresql:// (not asyncpg) — e.g. postgresql://user:pass@host:5432/db
# CHECKPOINT_URL=

# Gemini (required — powers the AI agent inside the sandbox)
GEMINI_API_KEY=

# GitHub (required — for repo cloning inside sandbox)
GITHUB_TOKEN=

# E2B (required — sandbox runtime for the agent)
E2B_API_KEY=
# Custom E2B agent template (optional — faster with pre-installed deps)
E2B_TEMPLATE_ID=devshowcase-agent
# Agent sandbox timeout in seconds (default: 600)
# AGENT_SANDBOX_TIMEOUT=600

# Token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Portfolio PR feature (optional)
# PORTFOLIO_REPO=
# PORTFOLIO_OWNER=

# Cloudflare R2 (optional — image storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Rate limiting
# RATE_LIMIT_RUNS_PER_HOUR=10

# CORS origins (comma-separated for multiple, e.g. http://localhost:3000,https://myapp.com)
# CORS_ORIGINS=["http://localhost:3000"]

# Database connection pool
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
