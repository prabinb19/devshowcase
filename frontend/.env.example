# NextAuth.js — session encryption secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# NextAuth.js — app URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth app credentials (for login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Backend API URL (http://localhost:8000 for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
